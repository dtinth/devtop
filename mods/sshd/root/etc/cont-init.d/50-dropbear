#!/usr/bin/with-contenv bash

# Install dropbear if not present
if ! command -v dropbear &>/dev/null; then
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq dropbear-bin
fi

# Generate persistent host keys in /config/ssh (survives container restarts)
mkdir -p /config/ssh
if [ ! -f /config/ssh/dropbear_ecdsa_host_key ]; then
    dropbearkey -t ecdsa -f /config/ssh/dropbear_ecdsa_host_key
fi
if [ ! -f /config/ssh/dropbear_ed25519_host_key ]; then
    dropbearkey -t ed25519 -f /config/ssh/dropbear_ed25519_host_key
fi

# Ensure abc user's .ssh dir exists with correct permissions
mkdir -p /config/.ssh
chmod 700 /config/.ssh
touch /config/.ssh/authorized_keys
chmod 600 /config/.ssh/authorized_keys
chown -R abc:abc /config/.ssh
